{
  "name": "frontend-next-js",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:prod": "env-cmd -f ./environments/.env.production -- node --max_old_space_size=100000 ./node_modules/next/dist/bin/next build",
    "build:test": "env-cmd -f ./environments/.env.test -- node --max_old_space_size=100000 ./node_modules/next/dist/bin/next build",
    "start:local": "env-cmd -f ./environments/.env.localhost -- next dev -p 4100",
    "start:prod": "env-cmd -f ./environments/.env.production -- next dev -p 4100",
    "start:test": "env-cmd -f ./environments/.env.test -- next dev -p 4100",
    "lint": "eslint",
    "start": "next start"
  },
  "dependencies": {
    "@hookform/error-message": "^2.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/crypto-js": "^4.2.2",
    "@types/file-saver": "^2.0.7",
    "@types/luxon": "^3.7.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "cookies-next": "^6.1.1",
    "crypto-js": "^4.2.0",
    "echarts-for-react": "^3.0.6",
    "env-cmd": "^11.0.0",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "fs": "^0.0.2",
    "just-debounce-it": "^3.2.0",
    "luxon": "^3.7.2",
    "next": "^16.2.9",
    "postcss": "^8.5.15",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "sass": "^1.101.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "title-case": "^4.3.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "typescript": "^6.0.3"
